generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VISITOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Doctor {
  id             String   @id @default(cuid())
  name           String
  specialization String
  experience     String
  biography      String
  photo          String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("doctors")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  duration    String
  icon        String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]

  @@map("services")
}

model Appointment {
  id        String            @id @default(cuid())
  fullName  String
  phone     String
  age       Int?
  gender    Gender            @default(UNSPECIFIED)
  notes     String?
  date      DateTime
  time      String
  status    AppointmentStatus @default(PENDING)
  serviceId String?
  service   Service?          @relation(fields: [serviceId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([date, time])
  @@map("appointments")
}

model Gallery {
  id        String   @id @default(cuid())
  title     String
  image     String
  category  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery")
}

model Schedule {
  id        String   @id @default(cuid())
  dayOfWeek Int
  opensAt   String
  closesAt  String
  breaks    Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedules")
}

model BlockedSlot {
  id        String   @id @default(cuid())
  date      DateTime
  time      String?
  reason    String?
  createdAt DateTime @default(now())

  @@map("blocked_slots")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model TreatmentCase {
  id                String   @id @default(cuid())
  beforeImage       String   @map("before_image")
  afterImage        String   @map("after_image")
  title             String
  category          String
  description       String
  treatmentDuration String   @map("treatment_duration")
  featured          Boolean  @default(false)
  published         Boolean  @default(false)
  consentApproved   Boolean  @default(false) @map("consent_approved")
  viewCount         Int      @default(0)
  blurRegions       Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("treatment_cases")
}

model Review {
  id            String   @id @default(cuid())
  patientName   String?
  rating        Int
  content       String
  approved      Boolean  @default(false)
  featured      Boolean  @default(false)
  appointmentId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("reviews")
}
